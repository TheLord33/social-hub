# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Redis ────────────────────────────────────────────────────────────────────
# Set automatically by docker-compose. Override here to use an external Redis.
# REDIS_URL=redis://localhost:6379

# ── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── OAuth — Twitter / X ──────────────────────────────────────────────────────
# Create app at https://developer.twitter.com/en/portal/dashboard
# Callback: http://localhost:3000/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── OAuth — Meta (Facebook + Instagram) ──────────────────────────────────────
# Create app at https://developers.facebook.com/apps
# Callback: http://localhost:3000/api/auth/meta/callback
META_APP_ID=
META_APP_SECRET=

# ── OAuth — LinkedIn ─────────────────────────────────────────────────────────
# Create app at https://www.linkedin.com/developers/apps
# Callback: http://localhost:3000/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── OAuth — TikTok ───────────────────────────────────────────────────────────
# Create app at https://developers.tiktok.com
# Callback: http://localhost:3000/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── OAuth — YouTube ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → YouTube Data API v3
# Callback: http://localhost:3000/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Reddit ───────────────────────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps
# Callback: http://localhost:3000/api/auth/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
