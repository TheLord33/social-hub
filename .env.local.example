# ─── Twitter / X ──────────────────────────────────────────────────────────────
# Create an app at https://developer.twitter.com/en/portal/dashboard
# Enable OAuth 2.0, set callback to: http://localhost:3030/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Meta (Facebook + Instagram) ──────────────────────────────────────────────
# Create an app at https://developers.facebook.com/apps
# Add "Facebook Login" and "Instagram" products
# Set callback to: http://localhost:3030/api/auth/meta/callback
# Required permissions: pages_show_list, pages_manage_posts, pages_read_engagement,
#                       instagram_basic, instagram_content_publish
META_APP_ID=
META_APP_SECRET=

# ─── LinkedIn ──────────────────────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
# Add products: "Share on LinkedIn", "Sign In with LinkedIn using OpenID Connect"
# Set callback to: http://localhost:3030/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── TikTok ───────────────────────────────────────────────────────────────────
# Create an app at https://developers.tiktok.com
# Add "Content Posting API" product, enable "PULL_FROM_URL" source
# Set callback to: http://localhost:3030/api/auth/tiktok/callback
# Note: TikTok uses "client_key", not "client_id"
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── YouTube (Google OAuth 2.0) ───────────────────────────────────────────────
# Go to https://console.cloud.google.com → New project → Enable "YouTube Data API v3"
# Create OAuth 2.0 credentials (Web application type)
# Add callbacks: http://localhost:3030/api/auth/youtube/callback
#                https://socialhub.bonnellio.com/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Reddit ───────────────────────────────────────────────────────────────────
# Create a web app at https://www.reddit.com/prefs/apps
# Set callback to: http://localhost:3030/api/auth/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Vercel Blob (media file storage for compose uploads) ────────────────────
# Automatically provisioned by Vercel — run: vercel env pull
BLOB_READ_WRITE_TOKEN=

# ─── Upstash Redis (token persistence on Vercel) ──────────────────────────────
# Create a free Redis database at https://upstash.com
# Connect it to your Vercel project via the Vercel Marketplace, or set manually:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3030
