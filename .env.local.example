# ── Domain ───────────────────────────────────────────────────────────────────
# Set to your public domain for production (Caddy will get a Let's Encrypt cert
# automatically). Leave as "localhost" for local development (Caddy uses a
# self-signed cert — run `docker exec <caddy-container> caddy trust` to trust it).
DOMAIN=localhost

# ── App ──────────────────────────────────────────────────────────────────────
# For production:  https://yourdomain.com
# For localhost:   https://localhost
NEXT_PUBLIC_BASE_URL=https://localhost
AUTH_URL=https://localhost

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Redis ────────────────────────────────────────────────────────────────────
# Set automatically by docker-compose. Override here to use an external Redis.
# REDIS_URL=redis://localhost:6379

# ── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── OAuth — Twitter / X ──────────────────────────────────────────────────────
# Create app at https://developer.twitter.com/en/portal/dashboard
# Callback: https://yourdomain.com/api/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── OAuth — Meta (Facebook + Instagram) ──────────────────────────────────────
# Create app at https://developers.facebook.com/apps
# Callback: https://yourdomain.com/api/auth/meta/callback
META_APP_ID=
META_APP_SECRET=

# ── OAuth — LinkedIn ─────────────────────────────────────────────────────────
# Create app at https://www.linkedin.com/developers/apps
# Callback: https://yourdomain.com/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── OAuth — TikTok ───────────────────────────────────────────────────────────
# Create app at https://developers.tiktok.com
# Callback: https://yourdomain.com/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── OAuth — YouTube ──────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → YouTube Data API v3
# Callback: https://yourdomain.com/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Reddit ───────────────────────────────────────────────────────────
# Create app at https://www.reddit.com/prefs/apps
# Callback: https://yourdomain.com/api/auth/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
